# ─── Server ───
PORT=10000
NODE_ENV=production

# ─── MongoDB (Render: set via dashboard) ───
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/Gravity?retryWrites=true&w=majority

# ─── JWT ───
JWT_SECRET=your_strong_jwt_secret_here_change_this
JWT_LIFETIME=1d

# ─── CORS (frontend URL) ───
CORS_ORIGIN=https://your-frontend.onrender.com
FRONTEND_URL=https://your-frontend.onrender.com

# ─── SMTP Email (optional) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Gravity HRMS <your-email@gmail.com>
ENABLE_EMAIL_NOTIFICATIONS=false

# ─── AI (supports: openai, openrouter, nvidia) ───
# For NVIDIA: provider=nvidia, api_key starts with nvapi-, base_url=https://integrate.api.nvidia.com/v1
# For OpenRouter: provider=openrouter, api_key starts with sk-or-v1-, model=nvidia/llama-3.3-nemotron-super-49b-v1.5
# For OpenAI: provider=openai, api_key starts with sk-, model=gpt-4o-mini
AI_PROVIDER=nvidia
OPENAI_API_KEY=nvapi-your-nvidia-key
OPENAI_MODEL=nvidia/nemotron-3-ultra-550b-a55b
AI_ENABLED=true
AI_MAX_TOKENS=1024
AI_TEMPERATURE=1
AI_API_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── Cloudinary (optional, for photo uploads) ───
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
