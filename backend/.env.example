# ─── Server ───
PORT=10000
NODE_ENV=production

# ─── MongoDB (Render: set via dashboard) ───
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/Gravity?retryWrites=true&w=majority

# ─── JWT ───
JWT_SECRET=your_strong_jwt_secret_here_change_this
JWT_LIFETIME=1d

# ─── CORS (frontend URL) ───
CORS_ORIGIN=https://your-frontend.onrender.com
FRONTEND_URL=https://your-frontend.onrender.com

# ─── SMTP Email (optional) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Gravity HRMS <your-email@gmail.com>
ENABLE_EMAIL_NOTIFICATIONS=false

# ─── AI / OpenRouter (optional) ───
AI_PROVIDER=openrouter
OPENAI_API_KEY=sk-or-v1-your-key
OPENAI_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
AI_ENABLED=false
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.3

# ─── Cloudinary (optional, for photo uploads) ───
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
